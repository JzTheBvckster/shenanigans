{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/auth/login",
            "dest": "/api/auth/login.js"
        },
        {
            "src": "/api/auth/register",
            "dest": "/api/auth/register.js"
        },
        {
            "src": "/api/auth/logout",
            "dest": "/api/auth/logout.js"
        },
        {
            "src": "/api/auth/session",
            "dest": "/api/auth/session.js"
        },
        {
            "src": "/api/auth/forgot-password",
            "dest": "/api/auth/forgot-password.js"
        },
        {
            "src": "/api/health",
            "dest": "/api/health.js"
        },
        {
            "src": "/api/dashboard/summary",
            "dest": "/api/dashboard/summary.js"
        },
        {
            "src": "/api/employees(.*)",
            "dest": "/api/employees/[...path].js"
        },
        {
            "src": "/api/projects(.*)",
            "dest": "/api/projects/[...path].js"
        },
        {
            "src": "/api/finance/invoices(.*)",
            "dest": "/api/finance/invoices/[...path].js"
        },
        {
            "src": "/api/workspace/(.*)",
            "dest": "/api/workspace/[...path].js"
        },
        {
            "src": "/pm-workspace/tasks",
            "dest": "/public/pm-workspace/tasks.html"
        },
        {
            "src": "/app/users",
            "dest": "/public/app/users.html"
        },
        {
            "src": "/app/employees",
            "dest": "/public/app/employees.html"
        },
        {
            "src": "/app/projects",
            "dest": "/public/app/projects.html"
        },
        {
            "src": "/app/finance",
            "dest": "/public/app/finance.html"
        },
        {
            "src": "/app/settings",
            "dest": "/public/app/settings.html"
        },
        {
            "src": "/app/reports",
            "dest": "/public/app/reports.html"
        },
        {
            "src": "/app",
            "dest": "/public/app/index.html"
        },
        {
            "src": "/workspace/projects",
            "dest": "/public/workspace/projects.html"
        },
        {
            "src": "/workspace/timesheet",
            "dest": "/public/workspace/timesheet.html"
        },
        {
            "src": "/workspace/requests",
            "dest": "/public/workspace/requests.html"
        },
        {
            "src": "/workspace/documents",
            "dest": "/public/workspace/documents.html"
        },
        {
            "src": "/workspace/team",
            "dest": "/public/workspace/team.html"
        },
        {
            "src": "/workspace/profile",
            "dest": "/public/workspace/profile.html"
        },
        {
            "src": "/workspace",
            "dest": "/public/workspace/index.html"
        },
        {
            "src": "/pm-workspace/team",
            "dest": "/public/pm-workspace/team.html"
        },
        {
            "src": "/pm-workspace/timesheet",
            "dest": "/public/pm-workspace/timesheet.html"
        },
        {
            "src": "/pm-workspace/requests",
            "dest": "/public/pm-workspace/requests.html"
        },
        {
            "src": "/pm-workspace/documents",
            "dest": "/public/pm-workspace/documents.html"
        },
        {
            "src": "/pm-workspace/profile",
            "dest": "/public/pm-workspace/profile.html"
        },
        {
            "src": "/pm-workspace",
            "dest": "/public/pm-workspace/index.html"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
                { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
                { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; object-src 'none';" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
            ]
        }
    ]
}
